# ============================================================================
# Tribe Run Tracker — configuration. Copiez ce fichier en `.env`.
#   cp .env.example .env  &&  docker compose up -d --build
# Toutes les valeurs ci-dessous ont des défauts fonctionnels : l'app démarre
# telle quelle, sans modification, sur http://localhost:8080.
# ============================================================================

# --- Port d'exposition de l'application (UI + API) ---
APP_PORT=8080

# --- Base de données PostgreSQL (interne au compose) ---
POSTGRES_DB=tribe
POSTGRES_USER=tribe
POSTGRES_PASSWORD=tribe

# --- Sécurité ---
# Clé de signature des sessions (JWT + cookies). À CHANGER en production.
SECRET_KEY=change-me-in-prod-please-32chars-min-secret

# --- Règles métier ---
# Seuil (en jours) au-delà duquel la donnée d'une équipe est marquée "périmée".
# Modifiable aussi à chaud dans l'écran Administration.
STALENESS_THRESHOLD_DAYS=7

# --- Données de démonstration ---
# true = seed automatique (~9 équipes, comptes de démo) au premier démarrage.
# Mettre à false pour démarrer avec une base vide.
SEED_DEMO=true

# ============================================================================
# Authentification
# ============================================================================

# --- 1) Compte de secours (breaking-glass) — toujours actif ---
# Si BREAKGLASS_PASSWORD est vide, un mot de passe aléatoire est généré et
# imprimé dans les logs du conteneur `app` au premier démarrage.
BREAKGLASS_EMAIL=admin@local
BREAKGLASS_PASSWORD=changeme-admin

# --- 2) OIDC (Authorization Code + PKCE) — optionnel ---
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8080/api/auth/oidc/callback
OIDC_SCOPES=openid email profile

# --- 3) SAML 2.0 (cible PingFederate) — optionnel ---
SAML_ENABLED=false
# Fournir SOIT une URL de métadonnées IdP, SOIT un chemin vers un fichier XML.
SAML_IDP_METADATA_URL=
SAML_IDP_METADATA_PATH=
SAML_SP_ENTITY_ID=http://localhost:8080/api/auth/saml/metadata
SAML_ACS_URL=http://localhost:8080/api/auth/saml/acs
# Certificat / clé du Service Provider (PEM sur une ligne, sans en-têtes), si signature requise.
SAML_SP_CERT=
SAML_SP_KEY=
