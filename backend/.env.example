# Tribe Cockpit - environment configuration (backend/app/config.py)
# Copy to .env and override ALL secrets for non-dev. Values below are DEV DEFAULTS.

# --- Core (MUST override in production) ---
SECRET_KEY=change-me-in-prod-please-32chars-min-secret   # session cookie signing - set a strong random value
SESSION_COOKIE=trt_session
SESSION_MAX_AGE_SECONDS=43200                            # 12h
COOKIE_SECURE=false                                      # set true behind TLS (production)
COOKIE_SAMESITE=lax                                      # lax | strict | none

# --- Hardening ---
LOGIN_MAX_ATTEMPTS=10                                    # failed logins per IP per window (0 = disabled)
LOGIN_WINDOW_SECONDS=300
AUDIT_RETENTION_DAYS=0                                   # 0 = keep forever

# --- Backups (docker compose --profile backup up -d) ---
BACKUP_KEEP=14
BACKUP_INTERVAL_SECONDS=86400

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=tribe
POSTGRES_USER=tribe
POSTGRES_PASSWORD=tribe                                  # MUST override in production

# --- App behaviour ---
APP_NAME=Tribe Cockpit
STALENESS_THRESHOLD_DAYS=7
SEED_DEMO=true                                           # set false in production

# --- Break-glass admin (recovery) ---
BREAKGLASS_EMAIL=admin@local
BREAKGLASS_PASSWORD=                                     # empty -> random generated & logged once at first boot

# --- OIDC (optional SSO) ---
OIDC_ENABLED=false
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://localhost:8443/api/auth/oidc/callback
OIDC_SCOPES=openid email profile

# --- SAML (optional SSO) ---
SAML_ENABLED=false
SAML_IDP_METADATA_URL=
SAML_IDP_METADATA_PATH=
SAML_SP_ENTITY_ID=https://localhost:8443/api/auth/saml/metadata
SAML_ACS_URL=https://localhost:8443/api/auth/saml/acs
SAML_SP_CERT=
SAML_SP_KEY=

# --- Deployment ---
# Single port: the container listens on :8443 (HTTPS) only. HTTP -> HTTPS
# redirection is handled by the infrastructure (e.g. GKE Gateway API), not the app.
# NOTE: APP_HTTPS_PORT is read by the ROOT docker-compose.yml (host-side mapping),
# not by backend/app/config.py. The Python process itself reads HTTPS_PORT.
APP_HTTPS_PORT=8443                                      # host port -> container :8443 (HTTPS)

# SMTP, modules, personas, report schedule, branding are configured at RUNTIME
# in the Admin UI (stored in the app_settings table), not via environment variables.
